# KKOO Admin Web — local development
# Copy to .env.local for `npm run dev`

VITE_API_BASE_URL=/api/v1
# Or direct API: VITE_API_BASE_URL=http://localhost:8080/api/v1

# Cross-app links (local dev ports — see docs/LOCAL_DEV.md)
VITE_BUYER_WEB_ORIGIN=http://localhost:5175
VITE_BIZ_WEB_ORIGIN=http://localhost:5174
VITE_ADMIN_WEB_ORIGIN=http://localhost:5173

# Production (set in CI or .env.production):
# VITE_API_BASE_URL=https://api.kkooapp.co.tz/api/v1
# VITE_MEDIA_BASE_URL=https://api.kkooapp.co.tz
# VITE_APP_ORIGIN=https://admin.kkooapp.co.tz
# VITE_BUYER_WEB_ORIGIN=https://kkooapp.co.tz
# VITE_BIZ_WEB_ORIGIN=https://biz.kkooapp.co.tz
# VITE_ADMIN_WEB_ORIGIN=https://admin.kkooapp.co.tz
